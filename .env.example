# 이 파일을 .env 로 복사한 뒤 값을 채우세요.  cp .env.example .env

# 답변 백엔드 선택:
#   anthropic  (기본) → Anthropic API 키 사용 (아래 ANTHROPIC_API_KEY 필요)
#   claude_cli        → 로컬 claude CLI(Claude Code) 사용. API 키 없이 기존 로그인으로 동작.
ANSWERER_BACKEND=anthropic

# Anthropic (Claude) API 키 — https://console.anthropic.com 에서 발급
# (ANSWERER_BACKEND=claude_cli 면 비워둬도 됨)
ANTHROPIC_API_KEY=sk-ant-...

# Outline 인스턴스 주소 (끝에 /api 를 붙이지 마세요)
#   - 클라우드:   https://your-team.getoutline.com
#   - self-hosted: https://wiki.your-company.com
OUTLINE_API_URL=https://wiki.your-company.com

# Outline API 토큰 — Outline 웹 > 좌측하단 프로필 > Settings > API Tokens 에서 발급
OUTLINE_API_TOKEN=ol_api_...
